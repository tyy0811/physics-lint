!01-lagrangebench/outputs/figures/.gitkeep
!02-physicsnemo-mgn/outputs/figures/.gitkeep
# Committed writeup-deliverable figures (rung 4b T11 + later). Match
# eps_t_traces_<sha>.{png,pdf} naming so figure_x.png ad-hoc plots stay
# gitignored. Pattern grows as writeups land.
!01-lagrangebench/outputs/figures/eps_t_traces_*.png
!01-lagrangebench/outputs/figures/eps_t_traces_*.pdf
01-lagrangebench/outputs/trajectories/**/*.npz
01-lagrangebench/outputs/trajectories/_local_mirror/**
!01-lagrangebench/outputs/trajectories/.gitkeep
01-lagrangebench/outputs/synthetic/**/*.h5
01-lagrangebench/outputs/synthetic/**/*.json
!01-lagrangebench/outputs/synthetic/.gitkeep
